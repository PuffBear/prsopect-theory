\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Behavioral decomposition of the collapse boundary. Each curve shows $P(\mathrm  {collapse} \mid w)$ at 300k steps. The null ($\alpha {=}\beta {=}1$, gray dashed) is the structural baseline. The $\lambda {=}1$, $\alpha {=}\beta {=}0.88$ curve (blue) shifts \emph  {left} of the null by 0.100, indicating that probability weighting alone facilitates coordination. The $\lambda {=}3$ (orange) and $\lambda {=}7$ (red) curves shift progressively \emph  {right}, indicating that loss aversion raises the centralization requirement. Vertical dashed lines mark $w_{\mathrm  {crit}}$ estimates; shaded bands show bootstrap 95\% confidence intervals. }}{7}{figure.caption.4}\protected@file@percent }
\newlabel{fig:decomposition}{{2}{7}{Behavioral decomposition of the collapse boundary. Each curve shows $P(\mathrm {collapse} \mid w)$ at 300k steps. The null ($\alpha {=}\beta {=}1$, gray dashed) is the structural baseline. The $\lambda {=}1$, $\alpha {=}\beta {=}0.88$ curve (blue) shifts \emph {left} of the null by 0.100, indicating that probability weighting alone facilitates coordination. The $\lambda {=}3$ (orange) and $\lambda {=}7$ (red) curves shift progressively \emph {right}, indicating that loss aversion raises the centralization requirement. Vertical dashed lines mark $\wcrit $ estimates; shaded bands show bootstrap 95\% confidence intervals}{figure.caption.4}{}}
\newlabel{fig:decomposition@cref}{{[figure][2][]2}{[1][6][]7}{}{}{}}
\citation{lalmohammed2025,anon2024risk}
\citation{tversky1992}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces $w_{\mathrm  {crit}}$ as a function of loss aversion $\lambda $ (Exp~B-Reduced, $\alpha {=}\beta {=}0.88$, 300k steps, 20 seeds per cell). Error bars show bootstrap 95\% confidence intervals. The monotone increase and non-overlapping CIs between $\lambda {=}1$ and $\lambda {=}7$ confirm the behavioral claim. Note: the $\lambda {=}7$ CI $[0.845, 0.858]$ should be interpreted with caution due to quasi-complete separation; see \Cref  {sec:results_behavioral}. }}{8}{figure.caption.5}\protected@file@percent }
\newlabel{fig:wcrit_lambda}{{3}{8}{$\wcrit $ as a function of loss aversion $\lambda $ (Exp~B-Reduced, $\alpha {=}\beta {=}0.88$, 300k steps, 20 seeds per cell). Error bars show bootstrap 95\% confidence intervals. The monotone increase and non-overlapping CIs between $\lambda {=}1$ and $\lambda {=}7$ confirm the behavioral claim. Note: the $\lambda {=}7$ CI $[0.845, 0.858]$ should be interpreted with caution due to quasi-complete separation; see \Cref {sec:results_behavioral}}{figure.caption.5}{}}
\newlabel{fig:wcrit_lambda@cref}{{[figure][3][]3}{[1][6][]8}{}{}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Three-way behavioral decomposition of $w_{\mathrm  {crit}}$ relative to the null model. ``Significant'' denotes that the conservative difference confidence interval excludes zero. $^{\dagger }$For $\lambda {=}7$, $w_{\mathrm  {crit}}$ is from bootstrap only; see footnote in \Cref  {sec:results_behavioral}.}}{8}{table.caption.6}\protected@file@percent }
\newlabel{tab:decomposition}{{2}{8}{Three-way behavioral decomposition of $\wcrit $ relative to the null model. ``Significant'' denotes that the conservative difference confidence interval excludes zero. $^{\dagger }$For $\lambda {=}7$, $\wcrit $ is from bootstrap only; see footnote in \Cref {sec:results_behavioral}}{table.caption.6}{}}
\newlabel{tab:decomposition@cref}{{[table][2][]2}{[1][8][]8}{}{}{}}
